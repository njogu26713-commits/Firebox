# ─── Required ───────────────────────────────────────────────
# Your WhatsApp session ID (generated from the dashboard after pairing)
SESSION_ID=

# Your WhatsApp number with country code, no + (e.g. 2547XXXXXXXX)
OWNER_NUMBER=

# Your name shown in bot responses
OWNER_NAME=Owner

# ─── Bot Settings ────────────────────────────────────────────
# Command prefix (default: .)
PREFIX=.

# Timezone (default: Africa/Nairobi)
TZ=Africa/Nairobi

# ─── API Keys (optional but recommended) ─────────────────────
# Google Gemini AI (for AI commands)
GEMINI_API_KEY=

# RapidAPI key (for various API commands)
RAPIDAPI_KEY=

# DeepAI key (for image generation)
DEEPAI_KEY=
